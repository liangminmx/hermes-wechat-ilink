# 微信iLink网关设置 (高级用户配置)
# WECHAT_ILINK_BASE_URL=https://ilink.tencent.com

# 插件配置
WECHAT_POLL_INTERVAL=5
WECHAT_QUEUE_MAX_SIZE=1000
WECHAT_API_TIMEOUT=15

# 调试配置
WECHAT_DEBUG=false
WECHAT_LOG_LEVEL=INFO

# 凭证存储 (自动管理)
# WECHAT_CREDENTIALS_PATH=~/.hermes/wechat_credentials.json

# Webhook服务器配置
WECHAT_WEBHOOK_ENABLED=false
WECHAT_WEBHOOK_PORT=8080
WECHAT_WEBHOOK_HOST=0.0.0.0

# ---
# 重要: Hermes插件不需要AI模型配置！
# 因为AI能力由Hermes主Agent提供
# 
# 相比wx-robot-ilink，我们不需要这些配置:
#   OPENAI_API_KEY=xxx
#   OPENAI_BASE_URL=xxx
#   OPENAI_MODEL=xxx
#   SYSTEM_PROMPT=xxx
# ---

# 环境变量加载方式:
# 1. 复制此文件为 .env
# 2. 编辑 .env 文件
# 3. 或者在启动Hermes前设置环境变量